#!/usr/bin/env bash
# Switch the active theme (light/dark) across wezterm, tmux and neovim.
# Source of truth: ~/.config/theme/current
set -euo pipefail

file="$HOME/.config/theme/current"

current() { cat "$file" 2>/dev/null || echo light; }

usage() {
	echo "usage: theme [light|dark|toggle|status]" >&2
	exit 1
}

target="${1:-status}"
case "$target" in
	status)
		echo "current theme: $(current)"
		exit 0
		;;
	toggle)
		if [ "$(current)" = dark ]; then target=light; else target=dark; fi
		;;
	light | dark) ;;
	*) usage ;;
esac

mkdir -p "$(dirname "$file")"
printf '%s\n' "$target" >"$file"

# tmux: re-source config on every running server so the statusline switches live
if command -v tmux >/dev/null 2>&1 && tmux ls >/dev/null 2>&1; then
	tmux source-file "$HOME/.tmux.conf" >/dev/null 2>&1 || true
fi

# wezterm: touch the config so any running instance reloads and re-reads the theme
# (wezterm always watches its own config; the external theme file alone is unreliable).
[ -f "$HOME/.wezterm.lua" ] && touch "$HOME/.wezterm.lua"

# neovim: applies on next launch, or live in a running instance via :Theme.

echo "theme set to $target"
echo "  wezterm + tmux: applied now   |   neovim: next launch"
